# Backend (FastAPI) environment — copy to .env and fill in.

ENVIRONMENT=development

# CORS: frontend origin(s), comma-separated
CORS_ORIGINS=http://localhost:3000

# Postgres (Docker). Matches docker/docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://vhb:vhb@localhost:5432/vhb

# Auth — FastAPI issues/verifies its own JWTs. Generate a strong secret for prod:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# S3-compatible object storage. Defaults match local MinIO.
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_PUBLIC_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=vhb_minio
STORAGE_SECRET_KEY=vhb_minio_secret
STORAGE_BUCKET=vhb-assets
STORAGE_REGION=us-east-1
STORAGE_PRESIGN_TTL_SECONDS=900

# Durable PostgreSQL worker. Development API embeds one worker automatically;
# production must run `uv run python -m app.worker` as a separate process.
WORKER_POLL_SECONDS=1
WORKER_LEASE_SECONDS=300
WORKER_MAX_ATTEMPTS=3

# Redis sessions, rate limits and cache.
REDIS_URL=redis://localhost:6379/0
AUTH_RATE_LIMIT_PER_MINUTE=20
